{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend workspace runner for auth, employee, and admin apps",
  "scripts": {
    "start:auth": "cd auth-app && npm run dev",
    "start:employee": "cd employee-app && npm run dev",
    "start:admin": "cd admin-app && npm run dev",
    "start:all": "npm-run-all --parallel start:auth start:employee start:admin",
    "build:auth": "cd auth-app && npm run build",
    "build:employee": "cd employee-app && npm run build",
    "build:admin": "cd admin-app && npm run build",
    "build:all": "npm-run-all build:auth build:employee build:admin",
    "lint:auth": "cd auth-app && npm run lint",
    "lint:employee": "cd employee-app && npm run lint",
    "lint:admin": "cd admin-app && npm run lint",
    "lint:all": "npm-run-all lint:auth lint:employee lint:admin"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
